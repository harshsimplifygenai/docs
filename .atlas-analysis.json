  "keyFeatures": [
    "AI voice agents powered by Google Gemini real-time audio",
    "Outbound call initiation via REST API",
    "Batch calling campaigns with retry logic and scheduling",
    "Knowledge base integration (Gemini File Search & Pinecone)",
    "Custom tool webhooks for mid-call backend integrations",
    "Post-call analysis with structured data extraction",
    "Native tools: call transfer, call end, SMS sending",
    "Voicemail detection and handling",
    "SIP URI support for PBX/telephony integrations",
    "Dynamic variables for personalized call scripts",
    "Call recording and transcripts",
    "Analytics dashboard for call metrics and costs"
  ],
